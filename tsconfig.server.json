{
  // ────────────────────────────────────────────────────────────────
  // Server-side typecheck config.
  //
  // Phase 8 (2026-05-16): expanded from a frontend-reuse guardrail
  // into the actual server-build config. Now covers:
  //   - `server/**/*.ts` — full backend (Express + Drizzle + Puppeteer)
  //   - `src/domain/calculator/**` — pure math, reused by future
  //     server-side PDF render + calculator validation.
  //   - `src/shared/**` — escapeHtml + any Node-safe utilities.
  //   - `src/components/calculator/{snapshotShape,derivedSummaryShape}.ts`
  //     — backend payload contracts.
  //   - `src/components/document-wizard/**` — buildOfferPdfHtml +
  //     agreementPdf + offerPdf + pdf-kit. Pure-string HTML builder
  //     consumed by server/modules/pdf/pdf.controller.ts to render
  //     documents via Puppeteer. NO React imports anywhere — all
  //     files in this tree are Node-safe by design.
  //
  // Run:
  //   npx tsc -p tsconfig.server.json --noEmit
  //
  // Sprint 4.E.2 (2026-05-17): expanded document-wizard glob from
  // just-types to the full module so the server can call
  // `buildOfferPdfHtml(payload)` directly.
  // ────────────────────────────────────────────────────────────────
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    // Bundler resolution lets imports omit the `.js` extension while
    // still working at runtime under tsx (used by `dev:server`,
    // `db:migrate`, `create-user`, etc.). This is what makes Drizzle
    // Kit's CJS loader happy on the same `server/db/schema/*.ts`
    // files. tsx normalises both forms; native `node --loader tsx`
    // also handles them.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "outDir": "dist-server"
  },
  "include": [
    "server/**/*.ts",
    "scripts/**/*.ts",
    "src/domain/**/*.ts",
    "src/shared/**/*.ts",
    "src/components/calculator/snapshotShape.ts",
    "src/components/calculator/derivedSummaryShape.ts",
    // Document-wizard subset that the PDF builder needs. We include
    // ONLY the pure-string HTML files — DocumentWizardPanel.tsx and
    // wizard/** are React, intentionally left out so the server tree
    // doesn't accidentally drag in any UI deps.
    "src/components/document-wizard/buildOfferPdfHtml.ts",
    "src/components/document-wizard/legalDefaults.ts",
    "src/components/document-wizard/types.ts",
    "src/components/document-wizard/wizard/layoutHelpers.ts",
    "src/components/document-wizard/offerPdf/**/*.ts",
    "src/components/document-wizard/agreementPdf/**/*.ts",
    "src/components/document-wizard/pdf-kit/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/node_modules/**"]
}
