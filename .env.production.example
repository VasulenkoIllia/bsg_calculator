# ────────────────────────────────────────────────────────────────────
# BSG Calculator — PRODUCTION environment template (Sprint 7.3).
#
# DO NOT COMMIT a filled-in copy of this file. Drop it onto the host
# (e.g. as `/srv/bsg/.env`) and let `docker compose` read it via the
# `env_file:` directive in `docker-compose.yml`.
#
# Every value marked `<REQUIRED>` MUST be replaced. The server's env
# validator (server/config/env.ts) refuses to boot if any of these
# placeholders survive into production.
# ────────────────────────────────────────────────────────────────────

# ─── App identity ───────────────────────────────────────────────────
APP_NAME=bsg-calculator
APP_DOMAIN=<REQUIRED — e.g. bsg.workflo.space>
# Public https URL of the SPA — embedded by Phase 9 HubSpot Note
# write-back as the clickable document link. MUST be the real https
# origin; the env loader rejects http://localhost in production.
APP_PUBLIC_URL=https://<APP_DOMAIN>
NODE_ENV=production
PORT=8080
TZ=Europe/Kyiv

# ─── Reverse proxy (Traefik) ────────────────────────────────────────
# `proxy` is the conventional name of the external Docker network
# Traefik attaches to. Match the actual network on your host:
#   docker network ls | grep -E 'proxy|traefik'
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
TRAEFIK_CERTRESOLVER=cf
# Number of trusted reverse-proxy hops. Traefik in front of the app
# = 1. If you have CloudFlare → Traefik → app, it's 2. Wrong value
# lets clients spoof X-Forwarded-For and bypass per-IP rate limits.
TRUST_PROXY_HOPS=1

# ─── Database ───────────────────────────────────────────────────────
# The application container reads DATABASE_URL directly. In compose
# we rebuild it from the discrete vars so changing DB_PASSWORD here
# propagates to the URL automatically.
DATABASE_URL=postgres://bsg:<DB_PASSWORD>@postgres:5432/bsg_calculator
DB_HOST=postgres
DB_PORT=5432
DB_USER=bsg
# REQUIRED: 32+ char random string. Generate with:
#   openssl rand -base64 32 | tr -d '+=/'
DB_PASSWORD=<REQUIRED>
DB_NAME=bsg_calculator
DB_POOL_MAX=10

# ─── Auth secrets ───────────────────────────────────────────────────
# REQUIRED: generate fresh per environment. The env loader REFUSES
# to boot if this is any of the well-known placeholder values.
#   openssl rand -base64 48
JWT_ACCESS_SECRET=<REQUIRED — run: openssl rand -base64 48>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
BCRYPT_COST=12

# ─── CORS / frontend ────────────────────────────────────────────────
# Single-container deploy: Express serves the SPA from the same
# origin, so CORS is effectively same-origin. Set this to your real
# https origin for the legacy frontend-build path.
FRONTEND_ORIGIN=https://<APP_DOMAIN>

# ─── HubSpot ────────────────────────────────────────────────────────
# REQUIRED: HubSpot Private App token. Format: `pat-na1-...`.
# Without it, the webhook processor 401's every event silently.
HUBSPOT_API_TOKEN=<REQUIRED — pat-na1-...>
HUBSPOT_API_BASE_URL=https://api.hubapi.com
# REQUIRED: secret you set when creating the HubSpot webhook
# subscription. The server verifies every webhook signature with
# HMAC-SHA-256 and rejects mismatches.
HUBSPOT_WEBHOOK_SECRET=<REQUIRED>
HUBSPOT_DEAL_PIPELINE_ID=
HUBSPOT_SYNC_TTL_SECONDS=300
# Pull ONLY companies whose company_type matches. Empty = pull all.
HUBSPOT_COMPANY_TYPE_FILTER=direct_client
HUBSPOT_BACKFILL_PAGE_SIZE=100
# Auto-run backfill on first deploy when companies table is empty.
# Default false in prod — backfill should be a deliberate operator
# action (run `docker compose exec app npm run hubspot:backfill`).
HUBSPOT_AUTO_BACKFILL=false

# ─── PDF / Puppeteer ────────────────────────────────────────────────
# Set by the Dockerfile to /usr/bin/chromium (system Chromium). No
# need to override here in prod.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PDF_RENDER_TIMEOUT_MS=30000
PUPPETEER_RENDERS_PER_BROWSER=1000
PUPPETEER_BROWSER_TTL_MS=86400000

# ─── Document numbering ─────────────────────────────────────────────
DOCUMENT_NUMBER_START=7100001

# ─── SPA static path ────────────────────────────────────────────────
# Where Express finds the built SPA. Matches the Dockerfile layout —
# don't change unless you know what you're doing.
SPA_DIST_DIR=/srv/spa

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_HTTP_REQUESTS=true

# ─── App image (optional) ───────────────────────────────────────────
# If you push the image to a registry, point compose at the tagged
# version here. Leave unset to build locally on `docker compose up`.
# APP_IMAGE=ghcr.io/your-org/bsg-calculator:1.0.0
