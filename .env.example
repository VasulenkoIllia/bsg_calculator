# ────────────────────────────────────────────────────────────────────
# BSG Calculator — environment configuration
# Copy this file to `.env` (gitignored) and fill in secrets locally.
# Production values live in Coolify / VPS deployment env, NOT here.
# ────────────────────────────────────────────────────────────────────

# ─── App / runtime ──────────────────────────────────────────────────
APP_NAME=bsg-calculator
APP_DOMAIN=bsg.workflo.space
NODE_ENV=development
PORT=8080
TZ=Europe/Kyiv

# ─── Reverse proxy (Traefik) — production only ──────────────────────
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
TRAEFIK_CERTRESOLVER=cf

# ─── Database (Postgres) ────────────────────────────────────────────
# Phase 8: single Postgres sibling container managed via docker-compose.
# Drizzle reads DATABASE_URL directly; the individual vars are exposed
# so docker-compose can render the postgres image config from one source.
DATABASE_URL=postgres://bsg:bsg_dev_password@localhost:5432/bsg_calculator
DB_HOST=localhost
DB_PORT=5432
DB_USER=bsg
DB_PASSWORD=bsg_dev_password
DB_NAME=bsg_calculator
# Connection pool size for the API process. Each Puppeteer render
# briefly borrows a connection; 10 is comfortable for a single VPS.
DB_POOL_MAX=10

# ─── Auth (JWT + bcrypt) ────────────────────────────────────────────
# IMPORTANT: regenerate both secrets per environment.
#   openssl rand -base64 48
# Access tokens are short-lived (15 min). Refresh tokens are 30 days
# and stored as SHA-256 hashes in the `refresh_tokens` table.
JWT_ACCESS_SECRET=replace_me_with_openssl_rand_base64_48_dev_only
JWT_REFRESH_SECRET=replace_me_with_a_different_openssl_rand_base64_48
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
# bcrypt cost. 12 ≈ 250ms hash on a typical VPS. Increase to 13 if
# the VPS CPU is significantly faster than the staging baseline.
BCRYPT_COST=12

# ─── CORS / frontend origin ─────────────────────────────────────────
# In Phase 8 the Express server also serves the SPA static bundle, so
# CORS only matters during local dev when Vite runs on its own port.
FRONTEND_ORIGIN=http://localhost:5173

# ─── HubSpot Private App (CRM v3) ───────────────────────────────────
# Generate the token at HubSpot → Settings → Integrations → Private Apps.
# Required scopes: crm.objects.companies.read, crm.objects.deals.read,
# crm.objects.owners.read, crm.objects.notes.write, crm.pipelines.read.
# Token format: `pat-eu1-<uuid>` (EU data centre).
HUBSPOT_API_TOKEN=
HUBSPOT_API_BASE_URL=https://api.hubapi.com
# The Gateway sales pipeline ID. Hard-coded after first lookup so we
# don't pay an API call on every list request. Leave blank in dev to
# fetch via `/crm/v3/pipelines/deals` on startup.
HUBSPOT_DEAL_PIPELINE_ID=
# Sync cadence guard. Used as fallback if webhooks miss an update.
# Number of seconds before a manual "Refresh from HubSpot" click is
# allowed to re-fetch the same record (debounce). 0 = always refetch.
HUBSPOT_SYNC_TTL_SECONDS=300
# Webhook HMAC secret. From HubSpot → Settings → Integrations →
# Private Apps → your app → Webhooks → "Client secret". Backend uses
# it to verify HMAC SHA-256 signatures on incoming /api/v1/hubspot/
# webhooks requests (header X-HubSpot-Signature-v3). Without this
# value set, the webhook endpoint MUST reject all requests.
HUBSPOT_WEBHOOK_SECRET=

# ─── Puppeteer / PDF rendering ──────────────────────────────────────
# Phase 8: Puppeteer + headless Chromium bundled into the same Docker
# image. In dev, leave PUPPETEER_EXECUTABLE_PATH empty and Puppeteer
# uses its own bundled Chromium download.
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=true
# Per-PDF render timeout, milliseconds. 30s comfortably covers the
# heaviest offer + agreement render in local benchmarks (~3-4s).
PDF_RENDER_TIMEOUT_MS=30000
# Browser recycle policy (defence against Chrome memory leak).
# Browser is killed + re-spawned after EITHER condition is hit.
PUPPETEER_RENDERS_PER_BROWSER=1000
PUPPETEER_BROWSER_TTL_MS=86400000

# ─── Document numbering ─────────────────────────────────────────────
# BSG-<7digit>-<6digit hubspot_id_suffix>. The 7-digit middle starts
# at 7100001 (Q14 confirmed). This value seeds the singleton row in
# `document_number_sequence` on first migration only — runtime reads
# it from the DB row, NOT from the env.
DOCUMENT_NUMBER_START=7100001

# ─── Logging / observability ────────────────────────────────────────
LOG_LEVEL=info
# When true, every inbound request is logged with timing + status.
LOG_HTTP_REQUESTS=true
